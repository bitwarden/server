@using Bit.Core.Billing.Organizations.PlanMigration.ValueObjects
@using Bit.Core.Enums
@model Bit.Admin.Billing.Models.OrganizationPlanMigrationCohorts.EditCohortViewModel
@{
    ViewData["Title"] = $"Cohort: {Model.FormModel.Name}";
    var unresolved = Model.CohortType as CohortType.UnresolvedMigration;
}

<div class="mx-auto" style="max-width: 768px;">
    <h1>Cohort: @Model.FormModel.Name</h1>

    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

<form method="post" asp-action="Edit" asp-route-id="@Model.FormModel.Id" id="cohort-form">
    <input type="hidden" asp-for="FormModel.Id" />

    <div class="mb-3">
        <label asp-for="FormModel.Name" class="form-label"></label>
        <input asp-for="FormModel.Name" class="form-control" placeholder="e.g., A1 (a) — Enterprise 2020 Annual" />
        <span asp-validation-for="FormModel.Name" class="text-danger"></span>
        <div class="form-text">Unique, max 255 characters. Used as the join key in CSV uploads.</div>
    </div>

    <div class="mb-3">
        <label asp-for="FormModel.MigrationPathSelection" class="form-label">Migration path</label>
        @if (Model.AssignmentState.HasNonPendingAssignments)
        {
            <div>
                <span class="me-1">🔒</span>
                @switch (Model.CohortType)
                {
                    case CohortType.ChurnOnly:
                        <span>None (Churn-only cohort)</span>
                        break;
                    case CohortType.Migration migration:
                        @($"{migration.Path.FromPlan.GetDisplayName()} → {migration.Path.ToPlan.GetDisplayName()}")
                        break;
                    case CohortType.UnresolvedMigration u:
                        <span class="text-warning">Unresolved migration #@u.Id</span>
                        break;
                }
            </div>
            <div class="form-text">
                Migration path cannot be changed because this cohort has @Model.AssignmentState.NonPendingAssignmentCount.ToString("N0") assignment(s) that have left the Pending state.
            </div>
        }
        else
        {
            <select asp-for="FormModel.MigrationPathSelection" class="form-select">
                @if (unresolved != null)
                {
                    <option value="@unresolved.Id" disabled selected>
                        Unresolved migration #@unresolved.Id
                    </option>
                }
                <option value="none">None (Churn-only cohort)</option>
                @foreach (var path in MigrationPaths.All)
                {
                    <option value="@((byte)path.Id)">
                        @($"{path.FromPlan.GetDisplayName()} → {path.ToPlan.GetDisplayName()}")
                    </option>
                }
            </select>
            <span asp-validation-for="FormModel.MigrationPathSelection" class="text-danger"></span>
            <div class="form-text">
                Pick a source → target plan pair to make this a <strong>Migration</strong> cohort,
                or <strong>None</strong> to define a <strong>Churn-only</strong> population
                (no migration scheduled; only the churn save-offer applies).
            </div>
        }
    </div>

    <div class="mb-3">
        <label asp-for="FormModel.ProactiveDiscountCouponCode" class="form-label">
            Proactive discount coupon <span class="text-muted">(optional)</span>
        </label>
        <input asp-for="FormModel.ProactiveDiscountCouponCode" class="form-control" placeholder="e.g., track-a-15-yr1" />
        <span asp-validation-for="FormModel.ProactiveDiscountCouponCode" class="text-danger"></span>
        <div class="form-text">
            Stripe coupon ID applied to Phase 2 of the SubscriptionSchedule at scheduling time. Validated against Stripe at save.
        </div>
    </div>

    <div class="mb-3">
        <label asp-for="FormModel.ChurnDiscountCouponCode" class="form-label">
            Churn discount coupon
            <span id="churn-optional-label" class="text-muted">(optional)</span>
        </label>
        <input asp-for="FormModel.ChurnDiscountCouponCode" class="form-control" placeholder="e.g., retain-q4-2026" />
        <span asp-validation-for="FormModel.ChurnDiscountCouponCode" class="text-danger"></span>
        <div class="form-text">
            Stripe coupon ID offered as a save-offer when an assigned org initiates self-serve cancellation.
            <strong>Required</strong> for churn-only cohorts. Validated against Stripe at save.
        </div>
    </div>
</form>

<div class="card my-4">
    <div class="card-body d-flex align-items-center">
        @if (Model.IsActive)
        {
            <form method="post" asp-action="Disable" asp-route-id="@Model.FormModel.Id">
                <button class="btn btn-secondary" type="submit">Disable</button>
            </form>
        }
        else
        {
            <form method="post" asp-action="Enable" asp-route-id="@Model.FormModel.Id">
                <button class="btn btn-success" type="submit">Enable</button>
            </form>
        }
        <div class="form-text ms-3 mb-0">
            When off, no migrations or save-offers fire for this cohort. Defaults to off; flip on once assignments are loaded.
        </div>
    </div>
</div>

<div class="d-flex mt-4">
    <button type="submit" class="btn btn-primary" form="cohort-form">Save</button>
    <a asp-action="Index" class="btn btn-secondary ms-2">Cancel</a>
    <div class="ms-auto d-flex">
        <form method="post" asp-action="Delete" asp-route-id="@Model.FormModel.Id"
              onsubmit="return confirm('Are you sure you want to delete this cohort?')">
            <button class="btn btn-danger" type="submit"><i class="fa fa-trash"></i> Delete</button>
        </form>
    </div>
</div>
</div>

@section Scripts {
    <script>
        (() => {
            const migrationPathSelect = document.getElementById('@Html.IdFor(m => m.FormModel.MigrationPathSelection)');
            if (!migrationPathSelect) return;
            const churnOptionalLabel = document.getElementById('churn-optional-label');
            const updateChurnOptionalLabel = () => {
                churnOptionalLabel.style.display = migrationPathSelect.value === 'none' ? 'none' : '';
            };
            migrationPathSelect.addEventListener('change', updateChurnOptionalLabel);
            updateChurnOptionalLabel();
        })();
    </script>
}
