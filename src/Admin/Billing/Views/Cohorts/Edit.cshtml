@using Bit.Core.Billing.Organizations.PlanMigration.ValueObjects
@using Bit.Core.Enums
@model Bit.Admin.Billing.Models.Cohorts.CohortFormModel
@{
    ViewData["Title"] = $"Cohort: {Model.Name}";
    var cohortType = (CohortType)(ViewData["CohortType"] ?? new CohortType.ChurnOnly());
    var unresolved = cohortType as CohortType.UnresolvedMigration;
    var isActive = (bool)(ViewData["IsActive"] ?? false);
}

<h1>Cohort: @Model.Name</h1>

<div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

<form method="post" asp-action="Edit" asp-route-id="@Model.Id" id="cohort-form">
    <input type="hidden" asp-for="Id" />

    <div class="mb-3">
        <label asp-for="Name" class="form-label"></label>
        <input asp-for="Name" class="form-control" placeholder="e.g., A1 (a) — Enterprise 2020 Annual" />
        <span asp-validation-for="Name" class="text-danger"></span>
        <div class="form-text">Unique, max 64 characters. Used as the join key in CSV uploads.</div>
    </div>

    <div class="mb-3">
        <label asp-for="MigrationPathSelection" class="form-label">Migration path</label>
        <select asp-for="MigrationPathSelection" class="form-select">
            @if (unresolved != null)
            {
                <option value="@unresolved.Id" disabled selected>
                    Unresolved migration #@unresolved.Id
                </option>
            }
            <option value="none">None (Churn-only cohort)</option>
            @foreach (var path in MigrationPaths.All)
            {
                <option value="@((byte)path.Id)">
                    @($"{path.FromPlan.GetDisplayName()} → {path.ToPlan.GetDisplayName()}")
                </option>
            }
        </select>
        <span asp-validation-for="MigrationPathSelection" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="ProactiveDiscountCouponCode" class="form-label">
            Proactive discount coupon <span class="text-muted">(optional)</span>
        </label>
        <input asp-for="ProactiveDiscountCouponCode" class="form-control" placeholder="e.g., track-a-15-yr1" />
        <span asp-validation-for="ProactiveDiscountCouponCode" class="text-danger"></span>
        <div class="form-text">
            Stripe coupon ID applied to Phase 2 of the SubscriptionSchedule at scheduling time. Validated against Stripe at save.
        </div>
    </div>

    <div class="mb-3">
        <label asp-for="ChurnDiscountCouponCode" class="form-label">
            Churn discount coupon
            <span id="churn-optional-label" class="text-muted">(optional)</span>
        </label>
        <input asp-for="ChurnDiscountCouponCode" class="form-control" placeholder="e.g., retain-q4-2026" />
        <span asp-validation-for="ChurnDiscountCouponCode" class="text-danger"></span>
        <div class="form-text">
            Stripe coupon ID offered as a save-offer when an assigned org initiates self-serve cancellation.
            <strong>Required</strong> for churn-only cohorts. Validated against Stripe at save.
        </div>
    </div>
</form>

<div class="d-flex mt-4">
    <button type="submit" class="btn btn-primary" form="cohort-form">Save</button>
    <a asp-action="Index" class="btn btn-secondary ms-2">Cancel</a>
    @if (isActive)
    {
        <form method="post" asp-action="Disable" asp-route-id="@Model.Id" class="ms-2">
            <button class="btn btn-secondary" type="submit">Disable</button>
        </form>
    }
    else
    {
        <form method="post" asp-action="Enable" asp-route-id="@Model.Id" class="ms-2">
            <button class="btn btn-success" type="submit">Enable</button>
        </form>
    }
    <div class="ms-auto d-flex">
        <form method="post" asp-action="Delete" asp-route-id="@Model.Id"
              onsubmit="return confirm('Are you sure you want to delete this cohort?')">
            <button class="btn btn-danger" type="submit">Delete</button>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        (() => {
            const migrationPathSelect = document.getElementById('@(nameof(Model.MigrationPathSelection))');
            const churnOptionalLabel = document.getElementById('churn-optional-label');
            const updateChurnOptionalLabel = () => {
                churnOptionalLabel.style.display = migrationPathSelect.value === 'none' ? 'none' : '';
            };
            migrationPathSelect.addEventListener('change', updateChurnOptionalLabel);
            updateChurnOptionalLabel();
        })();
    </script>
}
